.env
.env.local
.DS_Store
.idea/
.turbo/
.pnpm-store/
*.log
.devdigest/cache/
clones/
playwright-report/
test-results/

# emdash worktree config (local)
.emdash.json

# pr-self-review gate sentinel (local state, not for sharing)
.claude/.review-passed
